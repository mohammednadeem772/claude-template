{
  "_readme": "Claude Code permissions. Edit 'allow' list to match your project's commands.",

  "model": "claude-sonnet-4-5",

  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(pip *)",
      "Bash(python *)",
      "Bash(pytest *)",
      "Bash(php *)",
      "Bash(composer *)",
      "Bash(go *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git pull)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod *)",
      "Bash(curl -s *)",
      "Read(*)",
      "Write(src/**)",
      "Write(app/**)",
      "Write(tests/**)",
      "Write(docs/**)",
      "Write(public/**)",
      "Write(components/**)",
      "Write(pages/**)",
      "Write(styles/**)",
      "Write(*.md)",
      "Write(*.json)",
      "Write(*.config.*)"
    ],

    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(chmod 777 *)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(*.secret)",
      "Write(*.pem)",
      "Write(*.key)"
    ]
  },

  "hooks": {
    "SessionStart":  ".claude/hooks/session-start.sh",
    "PostToolUse":   ".claude/hooks/post-tool.sh",
    "PreCommit":     ".claude/hooks/pre-commit.sh"
  }
}
